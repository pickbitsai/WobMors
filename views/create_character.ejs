<%- include('partials/head', { title: 'New Character' }) %>
<main class="auth">
  <h1>Pick your gangster name</h1>
  <form method="post" action="/create-character">
    <label>Name<input name="name" required minlength="3" maxlength="24" placeholder='"Tony the Tiger"'></label>
    <button>Enter the Life</button>
  </form>
  <% if (err) { %><p class="err"><%= err %></p><% } %>
</main>
<%- include('partials/foot') %>
