<%- include('partials/head', { title: 'Claim Account' }) %>
<%- include('partials/hud') %>
<main class="auth">
  <h1>Claim your account</h1>
  <p class="muted">Set a username + password so you can log in as <strong><%= char.name %></strong> from another device. Until you claim, your character is tied to this browser.</p>
  <form method="post" action="/claim">
    <label>Username<input name="username" required minlength="3" autocomplete="username"></label>
    <label>Password<input name="password" type="password" required minlength="4" autocomplete="new-password"></label>
    <button>Claim</button>
  </form>
  <% if (err) { %><p class="err"><%= err %></p><% } %>
  <p class="alt"><a href="/hub">Skip — just keep playing</a></p>
</main>
<%- include('partials/foot') %>
