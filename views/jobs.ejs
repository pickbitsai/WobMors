<%- include('partials/head', { title: 'Jobs — ' + currentCity.name }) %>
<%- include('partials/hud') %>
<main>
  <h1>Jobs</h1>

  <nav class="city-tabs">
    <% for (const ci of cities) { %>
      <% const locked = char.level < ci.unlock_level; %>
      <% const isCurrent = ci.id === currentCity.id; %>
      <% const mastered = earnedPassives.find(p => p.id === ci.id); %>
      <a href="/jobs?city=<%= ci.id %>" class="city-tab <%= isCurrent ? 'active' : '' %> <%= locked ? 'locked' : '' %>">
        <%= ci.name %>
        <% if (locked) { %><span class="muted">· lvl <%= ci.unlock_level %>+</span><% } %>
        <% if (mastered) { %><span class="mastered">★ mastered</span><% } %>
      </a>
    <% } %>
  </nav>

  <section class="card">
    <p><strong><%= currentCity.name %></strong> —
      <span class="muted">master every tier-5 job (<%= masteryThreshold %>+ completions each) to earn:</span>
      <strong><%= currentCity.passive.description %></strong>
    </p>
    <% if (earnedPassives.find(p => p.id === currentCity.id)) { %>
      <p class="good">★ You've mastered this city. Passive active.</p>
    <% } %>
    <% if (char.level < currentCity.unlock_level) { %>
      <p class="err">Locked — reach level <%= currentCity.unlock_level %> to work in <%= currentCity.name %>.</p>
    <% } %>
  </section>

  <% let tier = 0; for (const j of jobs) { %>
    <% if (j.tier !== tier) { tier = j.tier; %>
      <h2 class="tier">Tier <%= tier %></h2>
    <% } %>
    <div class="job <%= char.level < j.unlock_level ? 'locked' : '' %>">
      <div class="job-info">
        <div class="job-name"><%= j.name %> <span class="muted">(lvl <%= j.unlock_level %>+)</span></div>
        <div class="job-payout">Energy <strong><%= j.energy %></strong> · Cash $<%= j.cash[0].toLocaleString() %>–$<%= j.cash[1].toLocaleString() %> · XP <%= j.xp %></div>
        <div class="job-mastery">Completions: <%= j.completions %><% if (j.tier === 5) { %> / <%= masteryThreshold %><% } %></div>
      </div>
      <div class="job-action">
        <form method="post" action="/jobs/<%= j.id %>">
          <button <%= char.level < j.unlock_level || char.energy < j.energy ? 'disabled' : '' %>>Do Job</button>
        </form>
      </div>
    </div>
  <% } %>
</main>
<%- include('partials/action_log') %>
<%- include('partials/foot') %>
