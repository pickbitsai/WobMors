<%- include('partials/head', { title: 'Register' }) %>
<main class="auth">
  <h1>Sign up to the family</h1>
  <form method="post" action="/register">
    <label>Username<input name="username" required minlength="3"></label>
    <label>Password<input name="password" type="password" required minlength="4"></label>
    <button>Register</button>
  </form>
  <% if (err) { %><p class="err"><%= err %></p><% } %>
  <p class="alt">Already made? <a href="/login">Log in</a></p>
</main>
<%- include('partials/foot') %>
